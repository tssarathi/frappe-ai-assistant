# Vyogo Stack — user-tunable configuration.
# cp .env.example .env, then edit the LLM section to point at your provider.

# ─── Where the site lives ──────────────────────────────
SITE_NAME=erpnext.local
ERPNEXT_ADMIN_PASSWORD=admin
ERPNEXT_PORT=8000
AGENT_PORT=8484

# ─── LLM (pick one) ────────────────────────────────────
# Option A — host's local Ollama (default; needs Ollama running on your host)
LLM_PROVIDER=ollama
LLM_BASE_URL=http://host.docker.internal:11434
LLM_API_KEY=
LLM_MODEL=qwen3.5:9b

# Option B — OpenAI
# LLM_PROVIDER=openai
# LLM_BASE_URL=https://api.openai.com/v1
# LLM_API_KEY=sk-...
# LLM_MODEL=gpt-4o-mini

# Option C — Anthropic
# LLM_PROVIDER=anthropic
# LLM_BASE_URL=https://api.anthropic.com/v1
# LLM_API_KEY=sk-ant-...
# LLM_MODEL=claude-sonnet-4-6

# ─── Logging ───────────────────────────────────────────
LOG_LEVEL=info

# ─── Advanced: agent service wiring ────────────────────
# These are set by docker-compose.yml for the normal Compose-based workflow.
# Uncomment and fill in only if you are running the agent process directly
# (outside Compose) or overriding defaults.
# AI_AGENT_MCP_SERVER_URL=http://mcp:8080/mcp
# AI_AGENT_FRAPPE_URL=http://erpnext:8000

# ─── Advanced: OpenTelemetry export ────────────────────
# Leave blank to disable OTEL export entirely (the agent no-ops).
# AI_AGENT_OTEL_ENDPOINT=
# AI_AGENT_OTEL_SERVICE_NAME=frappe-ai-agent
